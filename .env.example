# Server Config
PORT=5000
MONGODB_URI=mongodb://localhost:27017/jigzo

# Admin auth signing secret.
# Required in every DEPLOYED environment (Vercel Preview/Production) — the app
# refuses to start there without it. Locally it may be omitted (a clearly-named
# insecure dev fallback is used). Set a long, random, per-environment value.
JWT_SECRET=set_a_long_random_secret_here

# Frontend Config
# Public origin used to build reveal links and the CORS allow-list.
# Leave unset on Vercel to auto-derive from VERCEL_BRANCH_URL / VERCEL_URL.
FRONTEND_URL=http://localhost:5173
VITE_ENABLE_LOCAL_TEST=true

# Non-production email safety.
# In Preview/local, ALL outgoing email is redirected to this address (and the
# subject is prefixed with "[JIGZO STAGING]"). If unset/invalid, staging email
# is blocked entirely. Ignored in Production. Use a real inbox you control.
STAGING_EMAIL_REDIRECT=

# Mock Services Credentials (Placeholders)
PAYMENT_SECRET=mock_payment_secret_key
PAYMENT_WEBHOOK_SECRET=mock_webhook_secret_key
WHATSAPP_API_TOKEN=mock_whatsapp_token
WHATSAPP_PHONE_ID=mock_whatsapp_phone_id
IMAGE_STORAGE_PATH=./uploads

# Waitlist Email Service (Resend) - set real values in the deployment environment
RESEND_API_KEY=re_your_resend_key_here
EMAIL_FROM=JIGZO <info@jigzo.biz>

# Temporary Launch Lock Configuration (Disable billing & dispatch until Tap payment is active)
CHECKOUT_ENABLED=false
WHATSAPP_ENABLED=false
